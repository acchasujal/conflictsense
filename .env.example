AZURE_FOUNDRY_ENDPOINT=https://your-foundry-endpoint.azure.com
AZURE_API_KEY=your-api-key-here
AZURE_DEPLOYMENT_PRIMARY=gpt-4o
AZURE_DEPLOYMENT_BACKUP=gpt-4o-mini

# Provider chain order: Groq → OpenRouter → Nvidia (Gemini disabled)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Optional — force Tier 3 mock (blocked for custom_upload)
CONFLICTSENSE_FORCE_MOCK=0
LLM_TIMEOUT_S=8.0
